# Telegram Bot Credentials
# 1. Create a bot via @BotFather on Telegram to get your BOT_TOKEN
# 2. Message @userinfobot to find your CHAT_ID
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# Notification Settings
# Set to 'true' to get Telegram alerts immediately as they are scanned (instead of twice-daily digests)
NOTIFY_IMMEDIATELY=false

